#include <stdio.h>
#include <math.h>

int main() {
    int start, end, i, temp, d, sum, numDigits;
    
    printf("Enter range (start end): ");
    scanf("%d %d", &start, &end);
    
    for(i = start; i <= end; i++) {
        // Count digits
        numDigits = 0;
        temp = i;
        while(temp > 0) {
            numDigits++;
            temp /= 10;
        }
        
        // Calculate sum of digits raised to power
        temp = i;
        sum = 0;
        while(temp > 0) {
            d = temp % 10;
            sum += pow(d, numDigits);
            temp /= 10;
        }
        
        if(sum == i) {
            printf("%d ", i);
        }
    }
    return 0;
}
