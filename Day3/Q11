// to find the lcm of the two given numbers
#include <stdio.h>

int main() {
    int a, b, max;
    printf("enter numbers : ");

    scanf("%d%d", &a, &b);

    max = (a > b) ? a : b;

    while(1) {
        if(max % a == 0 && max % b == 0) {
            printf("LCM = %d", max);
            break;
        }
        max++;
    }

    return 0;
}
